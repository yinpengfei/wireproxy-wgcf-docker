# Bind to localhost by default. Use 0.0.0.0 only with firewall rules
# and SOCKS authentication.
BIND_ADDRESS=127.0.0.1
SOCKS_PORT=1081

# 1280 is conservative and usually stable for WARP.
WG_MTU=1280

# Optional. Leave empty to use the endpoint generated by wgcf.
# If handshakes time out, this IPv4 endpoint worked in testing:
# WG_ENDPOINT=162.159.192.1:2408
WG_ENDPOINT=

# Optional DNS used for socks5h requests. Empty keeps the DNS generated by wgcf.
WG_DNS=
RESOLVE_STRATEGY=auto

# Optional in-process DNS cache for socks5h. Leave TTL empty to disable.
# It deduplicates concurrent lookups of the same hostname.
DNS_CACHE_TTL=60s
DNS_CACHE_NEGATIVE_TTL=10s
DNS_CACHE_MAX_ENTRIES=1024

# Real WARP health check through the tunnel. Empty disables it.
CHECK_ALIVE=1.1.1.1
CHECK_ALIVE_INTERVAL=15

# Runtime log level: debug (upstream default) or error (suppresses routine logs
# and WireGuard DEBUG lines, but retains ERROR lines). Requires image 1.2.0+.
LOG_LEVEL=error

# Leave both empty for no authentication. If one is set, both must be set.
SOCKS_USERNAME=
SOCKS_PASSWORD=

# Resource presets: default, low, balanced.
# default keeps upstream buffer and Go runtime behavior unchanged.
MEMORY_PROFILE=default

# Fine-grained overrides in bytes. Empty uses the selected profile/default.
SOCKS_BUFFER_SIZE=
TCP_RECV_BUFFER_MIN=
TCP_RECV_BUFFER_DEFAULT=
TCP_RECV_BUFFER_MAX=
TCP_SEND_BUFFER_MIN=
TCP_SEND_BUFFER_DEFAULT=
TCP_SEND_BUFFER_MAX=

# Optional Go runtime and connection controls.
GOMEMLIMIT=
GOGC=
MAX_CONNECTIONS=
IDLE_TIMEOUT=
