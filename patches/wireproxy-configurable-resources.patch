+type managedListener struct {
+	net.Listener
+	semaphore   chan struct{}
+	idleTimeout time.Duration
+}
+
+type managedConn struct {
+	net.Conn
+	idleTimeout time.Duration
+	release     func()
+	closeOnce   sync.Once
+}
+
+func (l *managedListener) Accept() (net.Conn, error) {
+	for {
+		conn, err := l.Listener.Accept()
+		if err != nil {
+			return nil, err
+		}
+
+		if l.semaphore != nil {
+			select {
+			case l.semaphore <- struct{}{}:
+			default:
+				_ = conn.Close()
+				continue
+			}
+		}
+
+		managed := &managedConn{Conn: conn, idleTimeout: l.idleTimeout}
+		if l.semaphore != nil {
+			managed.release = func() { <-l.semaphore }
+		}
+		managed.refreshDeadline()
+		return managed, nil
+	}
+}
+
+func (c *managedConn) refreshDeadline() {
+	if c.idleTimeout > 0 {
+		_ = c.Conn.SetDeadline(time.Now().Add(c.idleTimeout))
+	}
+}
+
+func (c *managedConn) Read(p []byte) (int, error) {
+	c.refreshDeadline()
+	n, err := c.Conn.Read(p)
+	if n > 0 {
+		c.refreshDeadline()
+	}
+	return n, err
+}
+
+func (c *managedConn) Write(p []byte) (int, error) {
+	c.refreshDeadline()
+	n, err := c.Conn.Write(p)
+	if n > 0 {
+		c.refreshDeadline()
+	}
+	return n, err
+}
+
+func (c *managedConn) Close() error {
+	err := c.Conn.Close()
+	c.closeOnce.Do(func() {
+		if c.release != nil {
+			c.release()
+		}
+	})
+	return err
+}
