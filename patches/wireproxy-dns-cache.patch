diff --git a/dns_cache.go b/dns_cache.go
new file mode 100644
index 0000000..a73f6d5
--- /dev/null
+++ b/dns_cache.go
@@ -0,0 +1,110 @@
+package wireproxy
+
+import (
+	"context"
+	"errors"
+	"os"
+	"strconv"
+	"sync"
+	"time"
+)
+
+type dnsCacheEntry struct {
+	addrs   []string
+	err     error
+	expires time.Time
+}
+
+type dnsCache struct {
+	mu          sync.Mutex
+	entries     map[string]dnsCacheEntry
+	inflight    map[string]chan struct{}
+	ttl         time.Duration
+	negativeTTL time.Duration
+	maxEntries  int
+}
+
+func newDNSCacheFromEnv() *dnsCache {
+	ttl, err := time.ParseDuration(os.Getenv("DNS_CACHE_TTL"))
+	if err != nil || ttl <= 0 {
+		return nil
+	}
+
+	negativeTTL := 10 * time.Second
+	if raw := os.Getenv("DNS_CACHE_NEGATIVE_TTL"); raw != "" {
+		if value, parseErr := time.ParseDuration(raw); parseErr == nil && value > 0 {
+			negativeTTL = value
+		}
+	}
+
+	maxEntries := 1024
+	if raw := os.Getenv("DNS_CACHE_MAX_ENTRIES"); raw != "" {
+		if value, parseErr := strconv.Atoi(raw); parseErr == nil && value > 0 {
+			maxEntries = value
+		}
+	}
+
+	return &dnsCache{
+		entries:     make(map[string]dnsCacheEntry),
+		inflight:    make(map[string]chan struct{}),
+		ttl:         ttl,
+		negativeTTL: negativeTTL,
+		maxEntries:  maxEntries,
+	}
+}
+
+func (c *dnsCache) lookup(ctx context.Context, name string, resolve func(context.Context, string) ([]string, error)) ([]string, error) {
+	for {
+		now := time.Now()
+		c.mu.Lock()
+		if entry, ok := c.entries[name]; ok {
+			if now.Before(entry.expires) {
+				addrs := append([]string(nil), entry.addrs...)
+				c.mu.Unlock()
+				return addrs, entry.err
+			}
+			delete(c.entries, name)
+		}
+		if done, ok := c.inflight[name]; ok {
+			c.mu.Unlock()
+			select {
+			case <-done:
+				continue
+			case <-ctx.Done():
+				return nil, ctx.Err()
+			}
+		}
+		done := make(chan struct{})
+		c.inflight[name] = done
+		c.mu.Unlock()
+
+		addrs, err := resolve(ctx, name)
+		if err == nil && len(addrs) == 0 {
+			err = errors.New("no address found for: " + name)
+		}
+		ttl := c.ttl
+		if err != nil {
+			ttl = c.negativeTTL
+		}
+
+		c.mu.Lock()
+		if len(c.entries) >= c.maxEntries {
+			for key, entry := range c.entries {
+				if !now.Before(entry.expires) {
+					delete(c.entries, key)
+				}
+			}
+			if len(c.entries) >= c.maxEntries {
+				for key := range c.entries {
+					delete(c.entries, key)
+					break
+				}
+			}
+		}
+		c.entries[name] = dnsCacheEntry{addrs: append([]string(nil), addrs...), err: err, expires: now.Add(ttl)}
+		delete(c.inflight, name)
+		close(done)
+		c.mu.Unlock()
+		return addrs, err
+	}
+}
